{
  "name": "terra-echo-labs-music-assistant",
  "version": "1.0.0",
  "description": "Terra Echo Labs — Music Production Intelligence Suite",
  "main": "out/main/index.js",
  "author": "Will | Terra Echo Studios",
  "license": "MIT",
  "private": true,
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "backend": "python3.11 -m uvicorn backend.main:app --reload --port 8002",
    "start": "concurrently \"npm run backend\" \"npm run dev\"",
    "build:backend": "bash scripts/build-backend.sh",
    "package": "electron-vite build && electron-builder",
    "package:full": "bash scripts/build-backend.sh && electron-vite build && electron-builder"
  },
  "dependencies": {
    "@electron-toolkit/utils": "^4.0.0",
    "axios": "^1.6.7",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.22.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.17",
    "concurrently": "^8.2.2",
    "electron": "^28.2.0",
    "electron-builder": "^24.9.1",
    "electron-vite": "^2.0.0",
    "postcss": "^8.4.35",
    "tailwindcss": "^3.4.1",
    "vite": "^5.1.3"
  },
  "build": {
    "appId": "com.terraechostudios.musicassistant",
    "productName": "Terra Echo Labs",
    "copyright": "Copyright © 2026 Terra Echo Studios",
    "mac": {
      "target": [{ "target": "dmg", "arch": ["x64"] }],
      "icon": "resources/icon.png",
      "category": "public.app-category.music"
    },
    "dmg": {
      "title": "Terra Echo Labs ${version}",
      "background": null,
      "window": { "width": 540, "height": 380 }
    },
    "files": [
      "out/**/*"
    ],
    "extraResources": [
      {
        "from": "dist/tel-backend",
        "to": "tel-backend",
        "filter": ["**/*"]
      }
    ],
    "directories": {
      "output": "release",
      "buildResources": "resources"
    }
  }
}
